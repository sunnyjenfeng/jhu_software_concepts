(Q3: "What is the average GPA, GRE, GRE V, GRE AW of applicants who provide these) Tj
T* (metrics?",) Tj
T* (      "sql"= """) Tj
T* (      SELECT) Tj
T* (      ROUND\(AVG\(gpa\)::numeric, 2\) AS avg_gpa,) Tj
T* (      ROUND\(AVG\(gre\)::numeric, 2\) AS avg_gre,) Tj
T* (      ROUND\(AVG\(gre_v\)::numeric, 2\) AS avg_gre_v,) Tj
T* (      ROUND\(AVG\(gre_aw\)::numeric, 2\) AS avg_gre_aw) Tj
T* (      FROM applicants;) Tj
T* (      """,) Tj
T* () Tj
T* () Tj
T* (    avg_gpa, avg_gre, avg_gre_v, avg_gre_aw = query3_output[0]) Tj
T* () Tj
T* (    print\("Average GPA:", avg_gpa\)) Tj
T* (    print\("Average GRE:", avg_gre\)) Tj
T* (    print\("Average GRE V:", avg_gre_v\)) Tj
T* (    print\("Average GRE AW:", avg_gre_aw\)) Tj
T* () Tj
T* (    Take average of each corresponding vars and then round to 2 decimal points) Tj
T* () Tj
T* () Tj
T* (    Answer: Average GPA: 3.78) Tj
T* (    Average GRE: 262.00) Tj
T* (    Average GRE V: 161.54) Tj
T* (    Average GRE AW: 9.30) Tj
T* () Tj
T* (Q4: "What is their average GPA of American students in Fall 2026?",) Tj
T* (      "sql"= """) Tj
T* (      SELECT ROUND\(AVG\(gpa\)::numeric, 2\) AS avg_gpa) Tj
T* (      FROM applicants) Tj
T* (      WHERE us_or_international = 'American') Tj
T* (      AND term = 'Fall 2026';) Tj
T* (      """,) Tj
T* (Where clause put filter and table average and then round to 2 decimal points.) Tj
T* () Tj
T* (Answer: [\(Decimal\('3.79'\),\)]) Tj
T* () Tj
T* (Q5: "What percent of entries for Fall 2026 are Acceptances \(to two decimal places\)?",) Tj
T* (      "sql": """) Tj
T* (      SELECT) Tj
T* (      ROUND\() Tj
T* (      100.0 * SUM\() Tj
T* (      CASE WHEN status ILIKE '%Accepted%' THEN 1) Tj
T* (      ELSE 0) Tj
T* (      END) Tj
ET
endstream
