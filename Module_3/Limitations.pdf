T* (Q8: "How many entries from 2026 are acceptances from applicants who applied to) Tj
T* (Georgetown University, MIT, Stanford University, or Carnegie Mellon University for a PhD) Tj
T* (in Computer Science?",) Tj
T* (      "sql": """) Tj
T* (      SELECT COUNT\(*\)) Tj
T* (      FROM applicants) Tj
T* (      WHERE status = 'Accepted') Tj
T* (      AND degree = 'PhD') Tj
T* (      AND program ILIKE '%computer science%') Tj
T* (      AND EXTRACT\(YEAR FROM date_added\) = 2026) Tj
T* (      AND \() Tj
T* (      program ILIKE '%Georgetown%') Tj
T* (      OR program ILIKE '%Stanford%') Tj
T* (      OR program ILIKE '%Carnegie Mellon%') Tj
T* (      OR program ILIKE '%Massachusetts Institute of Technology%') Tj
T* (      OR program ILIKE '%MIT%') Tj
T* (      \);) Tj
T* (      """,) Tj
T* () Tj
T* (Where clause finds records status = 'Accepted' AND degree = 'PhD' and program includes) Tj
T* (the university names,) Tj
T* (Extract the year from date_added.) Tj
T* (Count to count all the selected records.) Tj
T* () Tj
T* (Answer: 0) Tj
T* () Tj
T* () Tj
T* (Q9: "Same as Q8, using LLM-generated program and university fields.",) Tj
T* (      "sql": """) Tj
T* (      SELECT COUNT\(*\) AS entries) Tj
T* (      FROM applicants) Tj
T* (      WHERE status ILIKE 'Accepted%') Tj
T* (      AND degree = 'PhD') Tj
T* (      AND llm_generated_program ILIKE '%computer science%') Tj
T* (      AND EXTRACT\(YEAR FROM date_added\) = 2026) Tj
T* (      AND \() Tj
T* (      llm_generated_university ILIKE '%Georgetown%') Tj
T* (      OR llm_generated_university ILIKE '%Stanford%') Tj
T* (      OR llm_generated_university ILIKE '%Carnegie Mellon%') Tj
T* (      OR llm_generated_university ILIKE '%Massachusetts Institute of Technology%') Tj
T* (      OR llm_generated_university ILIKE '%MIT%') Tj
T* (      \);) Tj
T* (      """,) Tj
T* (    Same as Question8, just use llm_generated_university and llm_generated_program instead) Tj
T* (    of program.) Tj
ET
endstream
