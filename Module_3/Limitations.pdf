T* (Q10: "How many entries for students applied for Fall 2026 term for Stanford Univerity) Tj
T* (Masters program per acceptance status? ",) Tj
T* (      "sql": """) Tj
T* (      SELECT) Tj
T* (      CASE) Tj
T* (      WHEN status ILIKE 'Accepted%' THEN 'Accepted') Tj
T* (      WHEN status ILIKE 'Rejected%' THEN 'Rejected') Tj
T* (      WHEN status ILIKE 'Wait listed%' THEN 'Waitlisted') Tj
T* (      WHEN status ILIKE 'Interview%' THEN 'Interview') Tj
T* (      ELSE status) Tj
T* (      END AS acceptance_status,) Tj
T* (      COUNT\(*\) AS num_entries) Tj
T* (      FROM applicants) Tj
T* (      WHERE term = 'Fall 2026') Tj
T* (      AND degree = 'Masters') Tj
T* (      AND llm_generated_university ILIKE '%Stanford%') Tj
T* (      GROUP BY acceptance_status) Tj
T* (      ORDER BY num_entries DESC;) Tj
T* (      """,) Tj
T* () Tj
T* (    Where clause put filter on term, degree, llm_generated_university. Case when created) Tj
T* (    categorical fields based on partial match.) Tj
T* (    Grouped by acceptance_status. Count entries per group.) Tj
T* () Tj
T* (    Answer: [\('Rejected', 68\), \('Accepted', 49\), \('Interview', 2\), \('Waitlisted', 2\)]) Tj
T* () Tj
T* () Tj
T* (Q11: "For students applied for Fall 2026 term for Stanford Univerity Masters program and) Tj
T* (got accepted, what is the percentage of international student?",) Tj
T* (      "sql": """) Tj
T* (      SELECT) Tj
T* (      ROUND\() Tj
T* (      100.0 * SUM\() Tj
T* (      CASE WHEN us_or_international = 'International' THEN 1) Tj
T* (      ELSE 0) Tj
T* (      END) Tj
T* (      \) / COUNT\(*\),) Tj
T* (      2) Tj
T* (      \) AS international_student_percent) Tj
T* (      FROM applicants) Tj
T* (      WHERE term = 'Fall 2026') Tj
T* (      AND degree = 'Masters') Tj
T* (      AND llm_generated_university ILIKE '%Stanford%') Tj
ET
endstream
